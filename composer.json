{
    "name": "olamilekan/laravel-google-sheets",
    "description": "A Laravel package for working with Google Sheets API with support for multiple spreadsheet connections",
    "keywords": [
        "laravel",
        "google-sheets",
        "spreadsheet",
        "google-api"
    ],
    "license": "MIT",
    "authors": [
        {
            "name": "Lamidi Olamilekan",
            "email": "lamidiolamilekan@gmail.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "google/apiclient": "^2.15",
        "illuminate/support": "^10.0|^11.0|^12.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0|^10.0",
        "phpunit/phpunit": "^10.0|^11.0"
    },
    "autoload": {
        "psr-4": {
            "Olamilekan\\GoogleSheets\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Olamilekan\\GoogleSheets\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Olamilekan\\GoogleSheets\\GoogleSheetsServiceProvider"
            ],
            "aliases": {
                "GoogleSheets": "Olamilekan\\GoogleSheets\\Facades\\GoogleSheets"
            }
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
